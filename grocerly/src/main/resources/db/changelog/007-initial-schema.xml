<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2025-12-5-add-picture-column" author="Kristin Vares">

        <addColumn tableName="product">
            <column name="picture" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="2025-12-5-pictures-adding" author="Kristin Vares">

        <update tableName="product">
            <column name="picture" value="bitter_sokolaad.jpg"/>
            <where>product_name = 'Bitter sokolaad'</where>
        </update>

        <update tableName="product">
            <column name="picture" value="sokolaadide_kombo.png"/>
            <where>product_name = 'Vanini sokolaadide valik.'</where>
        </update>

        <update tableName="product">
            <column name="picture" value="türgi_sokolaad.png"/>
            <where>product_name = 'Kunafa pistaatsiakreemiga sokolaad'</where>
        </update>

    </changeSet>

</databaseChangeLog>