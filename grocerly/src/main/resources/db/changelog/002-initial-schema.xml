<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="2025-12-10 Product tabel" author="Kristin Vares">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="public" tableName="product"/>
            </not>
        </preConditions>
        <createTable tableName="product">
            <column name="id" type="integer" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="product_name" type="text"></column>
            <column name="product_description" type="text"></column>
            <column name="price" type="NUMERIC(10,2)"></column>
            <column name="product_quantity" type="integer"></column>

        </createTable>
    </changeSet>

</databaseChangeLog>
